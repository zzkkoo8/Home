<view class="detail-container" wx:if="{{task}}">
  <view class="header">
    <text class="back" bindtap="goBack">&lt;</text>
    <text class="title">任务详情</text>
  </view>

  <view class="task-card">
    <text class="task-title">{{task.title}}</text>
    <text class="task-desc" wx:if="{{task.description}}">{{task.description}}</text>

    <view class="info-grid">
      <view class="info-item">
        <text class="label">积分奖励</text>
        <text class="value points">+{{task.points}}</text>
      </view>
      <view class="info-item">
        <text class="label">状态</text>
        <text class="value status status-{{task.status}}">{{statusMap[task.status]}}</text>
      </view>
      <view class="info-item">
        <text class="label">创建者</text>
        <text class="value">{{task.creator.nickname}}</text>
      </view>
      <view class="info-item" wx:if="{{task.executor}}">
        <text class="label">执行者</text>
        <text class="value">{{task.executor.nickname}}</text>
      </view>
    </view>
  </view>

  <view class="actions" wx:if="{{task.status === 'pending'}}">
    <button class="btn-primary" bindtap="handleApply">我来完成</button>
  </view>

  <view class="actions" wx:if="{{task.status === 'applying'}}">
    <button class="btn-primary" bindtap="handleApprove">审核通过</button>
    <button class="btn-secondary" bindtap="handleReject">审核拒绝</button>
  </view>
</view>
