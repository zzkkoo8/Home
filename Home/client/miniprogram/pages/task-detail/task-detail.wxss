.detail-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  padding: 16px;
  background: white;
}

.back {
  font-size: 20px;
  margin-right: 16px;
  color: #333;
}

.title {
  font-size: 18px;
}

.task-card {
  margin: 16px;
  background: white;
  border-radius: 12px;
  padding: 20px;
}

.task-title {
  font-size: 20px;
  font-weight: 600;
  margin-bottom: 12px;
  display: block;
}

.task-desc {
  font-size: 14px;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16px;
  display: block;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.info-item .label {
  font-size: 12px;
  color: #999;
}

.info-item .value {
  font-size: 14px;
}

.info-item .points {
  color: #ff9800;
  font-weight: 600;
}

.status {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
}

.status-pending { background: #e3f2fd; color: #1976d2; }
.status-applying { background: #fff3e0; color: #f57c00; }
.status-approved { background: #e8f5e9; color: #388e3c; }

.actions {
  margin: 20px 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.btn-primary {
  width: 100%;
  height: 48px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 24px;
  font-size: 16px;
}

.btn-secondary {
  width: 100%;
  height: 48px;
  background: white;
  color: #666;
  border: 1px solid #ddd;
  border-radius: 24px;
  font-size: 16px;
}
