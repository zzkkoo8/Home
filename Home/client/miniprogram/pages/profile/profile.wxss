.profile-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.user-card {
  display: flex;
  align-items: center;
  padding: 24px 16px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  margin-right: 16px;
  overflow: hidden;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 18px;
  font-weight: 500;
  margin-bottom: 4px;
}

.family {
  font-size: 14px;
  opacity: 0.9;
}

.menu-list {
  margin-top: 12px;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  background: white;
  margin-bottom: 1px;
}

.menu-item .value {
  color: #ff9800;
  font-weight: 500;
}

.menu-item .arrow {
  color: #ccc;
}

.logout-btn {
  margin: 24px 16px;
}

.logout-btn button {
  width: 100%;
  height: 48px;
  background: white;
  color: #ee0a24;
  border: 1px solid #ee0a24;
  border-radius: 24px;
  font-size: 16px;
}
