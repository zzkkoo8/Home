<view class="create-container">
  <view class="header">
    <text class="back" bindtap="goBack">&lt;</text>
    <text class="title">创建任务</text>
  </view>

  <view class="form">
    <view class="form-item">
      <text class="label">任务名称</text>
      <input placeholder="请输入任务名称" bindinput="onTitleInput" value="{{title}}" />
    </view>

    <view class="form-item">
      <text class="label">任务描述</text>
      <textarea placeholder="请输入任务描述（可选）" bindinput="onDescInput" value="{{description}}"></textarea>
    </view>

    <view class="form-item">
      <text class="label">积分奖励</text>
      <input type="number" placeholder="请输入积分数量" bindinput="onPointsInput" value="{{points}}" />
    </view>

    <view class="form-item">
      <text class="label">截止日期</text>
      <picker mode="date" bindchange="onDateChange" value="{{deadline}}">
        <view class="picker">{{deadline || '请选择'}}</view>
      </picker>
    </view>

    <button class="submit-btn" bindtap="createTask">创建任务</button>
  </view>
</view>
