.create-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  padding: 16px;
  background: white;
}

.back {
  font-size: 20px;
  margin-right: 16px;
  color: #333;
}

.title {
  font-size: 18px;
}

.form {
  margin-top: 20px;
  padding: 0 16px;
}

.form-item {
  background: white;
  border-radius: 8px;
  padding: 14px;
  margin-bottom: 12px;
}

.label {
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
  display: block;
}

.form-item input {
  width: 100%;
  font-size: 16px;
}

.submit-btn {
  width: 100%;
  height: 48px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 24px;
  font-size: 16px;
  margin-top: 24px;
}

.alt-action {
  text-align: center;
  margin-top: 24px;
  font-size: 14px;
  color: #666;
}

.link {
  color: #667eea;
  margin-left: 8px;
}
