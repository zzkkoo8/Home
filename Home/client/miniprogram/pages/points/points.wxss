.points-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.balance-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.balance-card .label {
  font-size: 14px;
  opacity: 0.9;
}

.balance-card .value {
  font-size: 48px;
  font-weight: 700;
  margin-top: 8px;
}

.tabs {
  display: flex;
  background: white;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 12px 0;
  font-size: 14px;
  color: #666;
  border-bottom: 2px solid transparent;
}

.tab.active {
  color: #667eea;
  border-bottom-color: #667eea;
}

.content {
  padding: 12px;
}

.log-item, .rank-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  padding: 14px;
  border-radius: 8px;
  margin-bottom: 8px;
}

.log-info {
  display: flex;
  flex-direction: column;
}

.reason {
  font-size: 14px;
}

.time {
  font-size: 12px;
  color: #999;
  margin-top: 4px;
}

.amount {
  font-size: 16px;
  font-weight: 600;
  color: #666;
}

.amount.positive {
  color: #ff9800;
}

.rank-info {
  display: flex;
  align-items: center;
  gap: 12px;
}

.rank-num {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  font-size: 12px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e0e0e0;
  color: #666;
}

.rank-num.rank-0 { background: #ffd700; color: #8b6914; }
.rank-num.rank-1 { background: #c0c0c0; color: #666; }
.rank-num.rank-2 { background: #cd7f32; color: #fff; }

.nickname {
  font-size: 14px;
}

.rank-item .points {
  color: #ff9800;
  font-weight: 500;
}

.empty {
  text-align: center;
  padding: 40px;
  color: #999;
}
